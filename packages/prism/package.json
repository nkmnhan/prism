{
  "name": "@nkmnhan/prism",
  "version": "0.0.1",
  "description": "Apple HIG liquid glass component library for React + Tailwind CSS",
  "keywords": [
    "react",
    "tailwind",
    "apple",
    "hig",
    "liquid-glass",
    "ui",
    "components"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.js"
    },
    "./styles": "./dist/prism.css",
    "./liquid-glass": "./dist/liquid-glass.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node -e \"const fs=require('fs');fs.copyFileSync('src/styles/prism.css','dist/prism.css');fs.copyFileSync('src/styles/liquid-glass.css','dist/liquid-glass.css')\"",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=3.4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^15.0.0",
    "postcss": "^8.5.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
